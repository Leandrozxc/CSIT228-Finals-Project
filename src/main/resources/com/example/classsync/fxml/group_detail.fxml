<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane
        fitToWidth="true"
        styleClass="shell-content"
        style="-fx-background: #191919; -fx-background-color: transparent;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.classsync.controller.GroupDetailController">
    <content>
        <VBox spacing="20.0" styleClass="shell-content">
            <padding>
                <Insets bottom="32.0" left="4.0" right="4.0" top="4.0" />
            </padding>

            <!-- Back -->
            <Button mnemonicParsing="false"
                    onAction="#goBack"
                    styleClass="cs-btn-ghost"
                    text="← Back to Groups" />

            <!-- Group header -->
            <HBox alignment="TOP_LEFT" spacing="16.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="groupName" text="Group Title" styleClass="page-title" />
                    <HBox fx:id="groupMeta" alignment="CENTER_LEFT" spacing="6.0" />
                </VBox>
                <Button fx:id="btnAddTask"
                        mnemonicParsing="false"
                        onAction="#showAddTaskDialog"
                        styleClass="cs-btn-primary"
                        text="+ Create Task" />
            </HBox>

            <!-- Content split — each column in its own panel -->
            <HBox spacing="16.0">

                <!-- Task Tracking Panel -->
                <VBox spacing="10.0" styleClass="detail-panel" HBox.hgrow="ALWAYS">
                    <Label text="TASK TRACKING" styleClass="detail-panel-title" />
                    <VBox fx:id="taskList" spacing="8.0" />
                </VBox>

                <!-- Team Roster Panel -->
                <VBox prefWidth="290.0" spacing="10.0" styleClass="detail-panel">
                    <Label text="TEAM ROSTER" styleClass="detail-panel-title" />
                    <VBox fx:id="memberList" spacing="6.0" />
                </VBox>

            </HBox>
        </VBox>
    </content>
</ScrollPane>