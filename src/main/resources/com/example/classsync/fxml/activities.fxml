<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane
        fitToWidth="true"
        styleClass="shell-content"
        style="-fx-background: #191919; -fx-background-color: transparent;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.classsync.controller.ActivitiesController">
    <content>
        <VBox spacing="16.0" styleClass="shell-content">
            <padding>
                <Insets bottom="32.0" left="4.0" right="4.0" top="4.0" />
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label text="Recent Notifications" styleClass="page-title" />
                    <Label fx:id="unreadLabel" text="All caught up" styleClass="workspace-subtitle" />
                </VBox>
                <Button mnemonicParsing="false"
                        onAction="#markAllRead"
                        styleClass="cs-btn-ghost"
                        style="-fx-text-fill: #e94560;"
                        text="Mark all as read" />
            </HBox>

            <!-- Notification list -->
            <VBox fx:id="notifList" styleClass="detail-panel" spacing="0" />
        </VBox>
    </content>
</ScrollPane>