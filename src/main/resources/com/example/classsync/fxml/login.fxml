<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #1a1a1e;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.classsync.controller.LoginController">
    <children>
        <VBox alignment="CENTER" layoutX="375.0" layoutY="125.0" prefWidth="350.0" spacing="20.0" style="-fx-background-color: #232329; -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.06); -fx-border-radius: 12;" AnchorPane.bottomAnchor="125.0" AnchorPane.topAnchor="125.0">
            <padding>
                <Insets bottom="40.0" left="32.0" right="32.0" top="40.0" />
            </padding>
            <children>
                <VBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Label text="ClassSync" textFill="#f0f0f4">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                        <Label text="Academic Group Accountability" textFill="#8a8a96">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="14.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Email Address" textFill="#8a8a96">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="emailField" promptText="Enter your university email" style="-fx-background-color: #2a2a31; -fx-text-fill: #f0f0f4; -fx-background-radius: 8; -fx-padding: 10;" />
                            </children>
                        </VBox>
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Password" textFill="#8a8a96">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-background-color: #2a2a31; -fx-text-fill: #f0f0f4; -fx-background-radius: 8; -fx-padding: 10;" />
                            </children>
                        </VBox>
                        <Label fx:id="errorLabel" wrapText="true" textFill="#e94560">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </VBox>

                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Sign In" />
            </children>
        </VBox>
    </children>
</AnchorPane>