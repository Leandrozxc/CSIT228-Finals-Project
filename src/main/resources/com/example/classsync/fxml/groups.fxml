<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane
        fitToWidth="true"
        styleClass="shell-content"
        style="-fx-background: #191919; -fx-background-color: transparent;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.classsync.controller.GroupsController">
    <content>
        <VBox spacing="12.0" styleClass="shell-content">
            <padding>
                <Insets bottom="32.0" left="4.0" right="4.0" top="4.0" />
            </padding>
            <Label text="Your Groups" styleClass="page-title" />
            <VBox fx:id="groupList" spacing="10.0" />
        </VBox>
    </content>
</ScrollPane>